# ============================================================
# CarDex – Variáveis de Ambiente
# ============================================================
# 1. Copie este arquivo → renomeie para ".env"
# 2. Preencha as keys abaixo (as opcionais funcionam sem key)
# 3. NUNCA faça commit do arquivo .env
# ============================================================

# ──────────────────────────────────────────────────────────────
# POKÉMON TCG API  (opcional — aumenta rate limit)
# Sem key: 1.000 req/dia | Com key: 20.000 req/dia
# Obter key: https://dev.pokemontcg.io/
# ──────────────────────────────────────────────────────────────
VITE_POKEMON_TCG_API_KEY=

# ──────────────────────────────────────────────────────────────
# POKETRACE API  (opcional — agrega TCGPlayer + eBay + CardMarket)
# Grátis: 250 calls/dia com key
# Obter key: https://poketrace.com/developers
# ──────────────────────────────────────────────────────────────
VITE_POKETRACE_API_KEY=

# ──────────────────────────────────────────────────────────────
# SCRYFALL  — grátis, sem key necessária
# Docs: https://scryfall.com/docs/api
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────
# MERCADO LIVRE  — grátis, sem key necessária
# Docs: https://developers.mercadolivre.com.br
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────
# TCGDEX  — grátis, sem key necessária
# Docs: https://tcgdex.dev
# ──────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────
# CARDMARKET API TCG (via RapidAPI) 🇪🇺
# Preços EUR por país (ES, DE, FR, IT) + USD + graded PSA/CGC
# Grátis: 100 req/dia · 30 req/min
# Obter key: https://rapidapi.com/tcggopro/api/cardmarket-api-tcg
# ──────────────────────────────────────────────────────────────
VITE_CARDMARKET_RAPIDAPI_KEY=0d993e5135msh71c856c06b335aep1360a2jsnddde102c316c
